    <script src="https://cdn.jsdelivr.net/npm/swiper@11/swiper-bundle.min.js"></script>
    <script>
        // Configuração do Carrossel
        const swiper = new Swiper('.swiper', {
            slidesPerView: 1,
            spaceBetween: 30,
            loop: true,
            pagination: { el: '.swiper-pagination', clickable: true },
            breakpoints: {
                768: { slidesPerView: 2 },
                1024: { slidesPerView: 3 }
            },
            autoplay: {
                delay: 3000,
                disableOnInteraction: false,
            }
        });

        // Toggle Menu Mobile
        function toggleMenu() {
            const menu = document.getElementById('navMenu');
            menu.classList.toggle('active');
        }

        // Função de Envio WhatsApp Melhorada
        function enviarParaWhatsapp() {
            const nome = document.getElementById('cliente_nome').value;
            const cpf = document.getElementById('cliente_cpf').value;
            const whats = document.getElementById('cliente_whatsapp').value;
            const valor = document.getElementById('cliente_valor').value;

            if(!nome || !whats || !valor) {
                alert("Por favor, preencha os campos obrigatórios.");
                return;
            }

            // Formatação bonita para o WhatsApp
            const msg = `*NOVA SIMULAÇÃO DO SITE*%0A%0A` +
                        `👤 *Nome:* ${nome}%0A` +
                        `📄 *CPF:* ${cpf || 'Não informado'}%0A` +
                        `📱 *WhatsApp:* ${whats}%0A` +
                        `💰 *Valor Desejado:* ${valor}%0A%0A` +
                        `_Aguardo o retorno de um consultor._`;

            window.open(`https://api.whatsapp.com/send?phone=5511943420915&text=${msg}`, '_blank');
        }

        // Máscaras de Input (Simples)
        document.getElementById('cliente_whatsapp').addEventListener('input', function(e) {
            let v = e.target.value.replace(/\D/g, "");
            v = v.replace(/^(\d{2})(\d)/g, "($1) $2");
            v = v.replace(/(\d)(\d{4})$/, "$1-$2");
            e.target.value = v;
        });

        document.getElementById('cliente_valor').addEventListener('input', function(e) {
            let v = e.target.value.replace(/\D/g, "");
            v = (v/100).toFixed(2) + '';
            v = v.replace(".", ",");
            v = v.replace(/(\d)(?=(\d{3})+(?!\d))/g, "$1.");
            e.target.value = "R$ " + v;
        });
    </script>
